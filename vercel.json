{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/gnews/:path*",
      "destination": "https://news.google.com/:path*"
    },
    {
      "source": "/((?!assets|api).*)",
      "destination": "/index.html"
    }
  ]
}
